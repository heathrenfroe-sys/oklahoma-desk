# Copy to .env and fill in. The .env file is gitignored.

# fred_pull.py — free key from https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# edgar_watch.py — SEC fair-access policy requires a declared identity
EDGAR_USER_AGENT=Firstname Lastname you@example.com

# edgar_watch.py / dashboard.py — where filing-alert notes are written and
# read. OPTIONAL: leave unset and alerts land in ./outbox. Point it at a
# notes system (e.g. an Obsidian vault folder) to integrate:
# DESK_ALERT_DIR=C:/path/to/your/notes/Filing Alerts
